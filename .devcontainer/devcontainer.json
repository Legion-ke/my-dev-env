{
  "name": "Legion-Ke-Env",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true
    },
    "ghcr.io/devcontainers/features/neovim:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    // Installs Mise and handles the shell hooks for you
    "ghcr.io/devcontainers-contrib/features/mise:1": {}
  },
  "remoteUser": "vscode",
  "postCreateCommand": "bash .devcontainer/bootstrap.sh",
  "customizations": {
    "vscode": {
      "extensions": ["fortytwo2.chezmoi", "jdx.mise-vscode"]
    }
  }
}
